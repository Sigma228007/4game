# Шаблон переменных окружения. Скопируй в .env и заполни:
#   cp .env.example .env

# ─── ОБЯЗАТЕЛЬНЫЕ ───

# PostgreSQL подключение
DATABASE_URL=postgresql://postgres:ТВОЙ_ПАРОЛЬ@localhost:5432/4game

# JWT секрет (минимум 32 случайных символа)
JWT_SECRET=замени_на_длинную_случайную_строку

# Порт сервера (по умолчанию 5000)
PORT=5000

# URL фронтенда (для email-ссылок)
FRONTEND_URL=https://4game-blush.vercel.app

# ─── EMAIL (опционально — без этого письма пишутся в консоль) ───

# Вариант 1: Gmail
# 1) Включи 2FA на Google-аккаунте
# 2) Создай App Password: https://myaccount.google.com/apppasswords
# 3) Вставь 16-значный пароль сюда
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-16-char-app-password
EMAIL_FROM=4Game <your-email@gmail.com>

# Вариант 2: Resend (3000 писем/мес бесплатно, нужен домен)
# SMTP_HOST=smtp.resend.com
# SMTP_PORT=587
# SMTP_USER=resend
# SMTP_PASS=re_xxxxxxxxxxxx
# EMAIL_FROM=4Game <noreply@your-domain.com>
